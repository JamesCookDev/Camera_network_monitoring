SIGZEL_BASE_URL=

CFTV_WORKER_API_KEY=

SIGZEL_DRY_RUN=true

AUTO_SYNC_CAMERAS=false

CAMERAS_FILE=cameras.json
SNAPSHOT_DIR=snapshots

ICMP_INTERVAL_SECONDS=180
RTSP_INTERVAL_SECONDS=300
MAIN_LOOP_SLEEP_SECONDS=5

MAX_ICMP_WORKERS=4
MAX_RTSP_WORKERS=1

PING_COUNT=3
PING_TIMEOUT_SECONDS=2

RTSP_OPEN_TIMEOUT_MS=4000
RTSP_READ_ATTEMPTS=8
RTSP_FRAME_WIDTH=640
JPEG_QUALITY=65

SNAPSHOT_MODE=keep_latest
SNAPSHOT_TTL_MINUTES=30

OFFLINE_AFTER_FAILURES=3
ONLINE_AFTER_SUCCESSES=1

HTTP_TIMEOUT_SECONDS=15
HTTP_RETRIES=3
HTTP_RETRY_BASE_SECONDS=2

SEND_RTSP_CREDENTIALS=false

LOG_LEVEL=INFO
